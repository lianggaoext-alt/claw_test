WECOM_TOKEN=your-token
WECOM_ENCODING_AES_KEY=your-encoding-aes-key
WECOM_CORP_ID=wwxxxxxxxxxxxxxxx
WECOM_AGENT_ID=1000002
WECOM_SECRET=your-secret

# OpenClaw bridge
OPENCLAW_CLI_PATH=openclaw
OPENCLAW_TIMEOUT_SECONDS=60
OPENCLAW_SESSION_PREFIX=wecom_
OPENCLAW_WORKSPACE_ROOT=/root/.openclaw/wecom-workspaces
OPENCLAW_ACL_ENABLED=false
OPENCLAW_ACL_FILE=/root/.openclaw/workspace/users_acl.json
OPENCLAW_NO_ACCESS_REPLY=你暂未开通权限，请联系管理员。
